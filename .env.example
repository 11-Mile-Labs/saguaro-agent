# Embeddings — text -> vector (OpenAI-compatible /embeddings endpoint)
EMBEDDINGS_BASE_URL=http://localhost:1234/v1
EMBEDDINGS_MODEL=text-embedding-bge-m3
EMBEDDINGS_API_KEY=

# LLM — prompt -> answer, used by knowledge_query synthesis (OpenAI-compatible /chat/completions)
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-chat
LLM_API_KEY=

# Storage backend — durable vector database, or omit for the filesystem fallback.
# SAGUARO_STORAGE_BACKEND is optional: when unset it is inferred as "chromadb"
# if VECTOR_STORE_BASE_URL is present, otherwise "filesystem".
SAGUARO_STORAGE_BACKEND=
VECTOR_STORE_BASE_URL=
VECTOR_STORE_API_KEY=
